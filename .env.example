APP_NAME="Rosa D'oro"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
SHOP_FRONTEND_URL=http://localhost:3000

APP_LOCALE=pl
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pl_PL
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# Override the Europe/Warsaw default if a specific environment needs UTC.
# APP_TIMEZONE=UTC

# ─── Logging ──────────────────────────────────────────────────────────────
LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database ─────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rosa_d_oro
DB_USERNAME=root
DB_PASSWORD=

# ─── Session / Cache / Queue ──────────────────────────────────────────────
# All three use the database driver — no Redis / Memcached.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# ─── Mail ─────────────────────────────────────────────────────────────────
# Local: log driver writes mails to storage/logs/laravel.log.
# Production: switch to smtp / postmark / ses and fill credentials below.
MAIL_MAILER=log
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="kontakt@rosadoro.pl"
MAIL_FROM_NAME="${APP_NAME}"

# ─── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to hit /api/* (Nuxt dev ports).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Contact form ─────────────────────────────────────────────────────────
# Where TeamNotificationMail goes after a /api/contact submission.
CONTACT_NOTIFICATION_EMAIL=kontakt@rosadoro.pl

# ─── Backoffice integration ───────────────────────────────────────────────
# Single shared bearer token for traffic in BOTH directions:
#   shop → backoffice: POST /api/shop/orders, GET /api/shop/pim/*
#   backoffice → shop: POST /api/admin/*, POST /api/panel/notify
# The same value MUST be set in backoffice's .env. Rotate together.
# Generate fresh: php -r "echo bin2hex(random_bytes(32)) . PHP_EOL;"
BACKOFFICE_INBOUND_URL=http://127.0.0.1:8000
BACKOFFICE_API_TOKEN=

# ─── Przelewy24 (P24) ─────────────────────────────────────────────────────
# Sandbox flag — flip to false on production with the live POS credentials.
# Auth (Basic): pos_id : reports_key. Sign (SHA-384): includes crc_key.
# `merchant_id` defaults to `pos_id` (same number on most accounts) — set
# P24_MERCHANT_ID only if your account has multiple POS under one merchant.
P24_SANDBOX=true
P24_POS_ID=
P24_REPORTS_KEY=
P24_CRC_KEY=
# Legacy "klucz do zamówień" — not used by the REST API, kept for reference.
P24_API_KEY=
